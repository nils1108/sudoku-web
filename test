	def _difficulty_label(self):
		return self.current_difficulty.capitalize()

	def _update_difficulty_button_state(self):
		for difficulty, btn in self.difficulty_buttons.items():
			if difficulty == self.current_difficulty:
				btn.configure(bg=self.colors["accent_dark"])
			else:
				btn.configure(bg=self.colors["accent"])

	def generate_new(self, difficulty):
		try:
			self.current_puzzle, self.current_solution = generate_sudoku(difficulty)
		except ValueError as error:
			messagebox.showerror("Fehler", str(error))
			return

		self.current_difficulty = difficulty
		self.current_board = deepcopy(self.current_puzzle)
		self.fixed_cells = {
			(r, c)
			for r in range(GRID_SIZE)
			for c in range(GRID_SIZE)
			if self.current_puzzle[r][c] != 0
		}
		self.selected_cell = None
		self.showing_solution = False
		self.game_locked = False
		self.hint_used = False
		self._cancel_hint_feedback()
		self._stop_flash_animation()
		self.solution_btn.configure(text="Loesung anzeigen")
		self.solution_btn.configure(state="normal")
		self.hint_btn.configure(text="Tipp (1x)", state="normal")
		self._update_difficulty_button_state()
		self.hide_number_pad()
		self.status_label.configure(text=f"Neues Raetsel erstellt: {self._difficulty_label()}")
		self.draw_grid()

	def toggle_solution(self):
		if self.current_puzzle is None or self.current_solution is None:
			return
		if self.game_locked:
			self.status_label.configure(text="Loesung bereits gezeigt - starte ein neues Spiel")
			return

		self.showing_solution = True
		self.game_locked = True
		self.selected_cell = None
		self.solution_btn.configure(text="Loesung gezeigt", state="disabled")
		self.hint_btn.configure(state="disabled")
		self.hide_number_pad()
		self.status_label.configure(text="Loesung eingeblendet - Spiel ist beendet")
		self.draw_grid()

	def draw_grid(self):
		self.canvas.delete("all")
		if self.current_board is None:
			return

		size = self.board_size
		padding = self.board_padding
		cell_size = self.cell_size
		display_grid = self.current_solution if self.showing_solution else self.current_board

		# Decorative background blocks for a warmer board appearance.
		for box_row in range(BOX_SIZE):
			for box_col in range(BOX_SIZE):
				x1 = padding + box_col * BOX_SIZE * cell_size
				y1 = padding + box_row * BOX_SIZE * cell_size
				x2 = x1 + BOX_SIZE * cell_size
				y2 = y1 + BOX_SIZE * cell_size
				if (box_row + box_col) % 2 == 0:
					self.canvas.create_rectangle(x1, y1, x2, y2, fill="#fff7e6", outline="")

		if self.selected_cell and not self.showing_solution:
			selected_row, selected_col = self.selected_cell

			row_y1 = padding + selected_row * cell_size
			row_y2 = row_y1 + cell_size
			self.canvas.create_rectangle(
				padding,
				row_y1,
				size - padding,
				row_y2,
				fill="#dff3ef",
				outline="",
			)

			col_x1 = padding + selected_col * cell_size
			col_x2 = col_x1 + cell_size
			self.canvas.create_rectangle(
				col_x1,
				padding,
				col_x2,
				size - padding,
				fill="#e8f5f2",
				outline="",
			)

			self.canvas.create_rectangle(
				col_x1,
				row_y1,
				col_x2,
				row_y2,
				fill="#c8ece5",
				outline="",
			)

		if self.flash_cell and self.flash_visible and not self.showing_solution:
			flash_row, flash_col = self.flash_cell
			fx1 = padding + flash_col * cell_size
			fy1 = padding + flash_row * cell_size
			fx2 = fx1 + cell_size
			fy2 = fy1 + cell_size
			fill = "#ffd8d8" if self.flash_type == "wrong" else "#ffeeb3"
			outline = "#c1121f" if self.flash_type == "wrong" else "#c47f00"
			self.canvas.create_rectangle(fx1, fy1, fx2, fy2, fill=fill, outline=outline, width=2)

		for i in range(GRID_SIZE + 1):
			line_color = self.colors["line_thick"] if i % BOX_SIZE == 0 else self.colors["line_thin"]
			line_width = 3 if i % BOX_SIZE == 0 else 1
			offset = padding + i * cell_size
			self.canvas.create_line(padding, offset, size - padding, offset, fill=line_color, width=line_width)
			self.canvas.create_line(offset, padding, offset, size - padding, fill=line_color, width=line_width)

		for row in range(GRID_SIZE):
			for col in range(GRID_SIZE):
				value = display_grid[row][col]
				if value == 0:
					continue

				x = padding + col * cell_size + cell_size / 2
				y = padding + row * cell_size + cell_size / 2
				is_given = self.current_puzzle[row][col] != 0

				if self.showing_solution and not is_given:
					text_color = self.colors["solution"]
				elif not is_given:
					text_color = "#1a936f"
				else:
					text_color = self.colors["given"]

				text_weight = "normal" if not is_given and not self.showing_solution else "bold"
				text_family = "Trebuchet MS" if not is_given and not self.showing_solution else "Cambria"

				self.canvas.create_text(
					x,
					y,
					text=str(value),
					fill=text_color,
					font=(text_family, 24, text_weight),
				)

		if self.selected_cell and not self.showing_solution:
			row, col = self.selected_cell
			x1 = padding + col * cell_size
			y1 = padding + row * cell_size
			x2 = x1 + cell_size
			y2 = y1 + cell_size
			self.canvas.create_rectangle(x1, y1, x2, y2, outline="#007f73", width=3)

	def on_canvas_click(self, event):
		if self.current_board is None:
			return
		if self.game_locked:
			self.status_label.configure(text="Spiel beendet - starte ein neues Spiel")
			return

		if self.showing_solution:
			self.status_label.configure(text="Loesung aktiv - erst auf Raetsel anzeigen wechseln")
			return

		col = int((event.x - self.board_padding) / self.cell_size)
		row = int((event.y - self.board_padding) / self.cell_size)

		if not (0 <= row < GRID_SIZE and 0 <= col < GRID_SIZE):
			self.selected_cell = None
			self.hide_number_pad()
			self.draw_grid()
			return

		self.selected_cell = (row, col)
		if (row, col) in self.fixed_cells:
			self.hide_number_pad()
			self.status_label.configure(text="Vorgegebenes Feld ausgewaehlt")
		else:
			self.show_number_pad(row, col)
			self.status_label.configure(text=f"Feld ({row + 1}, {col + 1}) ausgewaehlt")

		self.draw_grid()

	def show_number_pad(self, row, col):
		self.pad_label.configure(text=f"Zahl fuer Feld ({row + 1}, {col + 1}) waehlen")
		if not self.number_pad.winfo_ismapped():
			self.number_pad.pack(pady=(0, 12))

	def hide_number_pad(self):
		if self.number_pad.winfo_ismapped():
			self.number_pad.pack_forget()

	def place_number(self, value):
		if self.selected_cell is None or self.showing_solution or self.game_locked:
			return

		row, col = self.selected_cell
		if (row, col) in self.fixed_cells:
			return

		self.current_board[row][col] = value
		self.draw_grid()
		self.check_if_completed()

	def clear_selected_cell(self):
		if self.selected_cell is None or self.showing_solution or self.game_locked:
			return

		row, col = self.selected_cell
		if (row, col) in self.fixed_cells:
			return

		self.current_board[row][col] = 0
		self.draw_grid()

	def on_key_press(self, event):
		if self.selected_cell is None or self.showing_solution or self.game_locked or self.current_board is None:
			return

		row, col = self.selected_cell
		if (row, col) in self.fixed_cells:
			return

		if event.char in "123456789":
			self.current_board[row][col] = int(event.char)
			self.draw_grid()
			self.check_if_completed()
		elif event.keysym in ("BackSpace", "Delete") or event.char == "0":
			self.current_board[row][col] = 0
			self.draw_grid()

	def check_if_completed(self):
		if any(0 in row for row in self.current_board):
			return

		if self.current_board == self.current_solution:
			self.status_label.configure(text="Perfekt geloest!")
			self.game_locked = True
			self.hint_btn.configure(state="disabled")
			self.hide_number_pad()
			self.show_win_popup()
		else:
			self.status_label.configure(text="Noch nicht korrekt - pruefe deine Eingaben")

	def use_hint(self):
		if self.current_board is None:
			return
		if self.game_locked or self.showing_solution:
			self.status_label.configure(text="Kein Tipp moeglich - Spiel ist beendet")
			return
		if self.hint_used:
			self.status_label.configure(text="Tipp wurde bereits verwendet")
			return

		wrong_cells = []
		for row in range(GRID_SIZE):
			for col in range(GRID_SIZE):
				if (row, col) in self.fixed_cells:
					continue
				value = self.current_board[row][col]
				if value != 0 and value != self.current_solution[row][col]:
					wrong_cells.append((row, col, value))

		if wrong_cells:
			row, col, value = random.choice(wrong_cells)
			self.selected_cell = (row, col)
			self.start_cell_flash(row, col, "wrong")
			self.show_hint_feedback(f"Tipp: Feld ({row + 1}, {col + 1}) hat aktuell eine falsche Zahl ({value}).")
			self.hint_used = True
			self.hint_btn.configure(text="Tipp genutzt", state="disabled")
			self.status_label.configure(text="Tipp genutzt: falsche Zahl markiert")
			return

		for row in range(GRID_SIZE):
			empty_cols = [col for col in range(GRID_SIZE) if self.current_board[row][col] == 0]
			if len(empty_cols) == 1:
				col = empty_cols[0]
				solution_value = self.current_solution[row][col]
				self.selected_cell = (row, col)
				self.start_cell_flash(row, col, "easy")
				self.show_hint_feedback(
					f"Tipp: Reihe {row + 1} ist leicht. In Spalte {col + 1} gehoert die {solution_value}."
				)
				self.hint_used = True
				self.hint_btn.configure(text="Tipp genutzt", state="disabled")
				self.status_label.configure(text="Tipp genutzt: einfache Reihe gefunden")
				return

		self.show_hint_feedback("Aktuell gibt es keine falsche Zahl oder einfache Reihe mit nur einem freien Feld.")

	def show_hint_feedback(self, text, duration_ms=5000):
		self._cancel_hint_feedback()
		self.hint_label.configure(text=text)
		self.hint_message_after_id = self.root.after(duration_ms, lambda: self.hint_label.configure(text=""))

	def _cancel_hint_feedback(self):
		if self.hint_message_after_id is not None:
			self.root.after_cancel(self.hint_message_after_id)
			self.hint_message_after_id = None
		self.hint_label.configure(text="")

	def start_cell_flash(self, row, col, flash_type):
		self._stop_flash_animation()
		self.flash_cell = (row, col)
		self.flash_type = flash_type
		self.flash_visible = True
		self.flash_remaining = 8
		self._run_flash_step()

	def _run_flash_step(self):
		self.draw_grid()
		self.flash_visible = not self.flash_visible
		self.flash_remaining -= 1
		if self.flash_remaining <= 0:
			self._stop_flash_animation()
			self.draw_grid()
			return
		self.flash_after_id = self.root.after(130, self._run_flash_step)

	def _stop_flash_animation(self):
		if self.flash_after_id is not None:
			self.root.after_cancel(self.flash_after_id)
			self.flash_after_id = None
		self.flash_cell = None
		self.flash_type = None
		self.flash_visible = False
		self.flash_remaining = 0

	def show_win_popup(self):
		popup = tk.Toplevel(self.root)
		popup.title("Gewonnen")
		popup.configure(bg="#fff8ef")
		popup.resizable(False, False)
		popup.transient(self.root)
		popup.grab_set()

		popup_width = 420
		popup_height = 250
		x_pos = self.root.winfo_rootx() + (self.root.winfo_width() - popup_width) // 2
		y_pos = self.root.winfo_rooty() + (self.root.winfo_height() - popup_height) // 2
		popup.geometry(f"{popup_width}x{popup_height}+{x_pos}+{y_pos}")

		card = tk.Frame(popup, bg="#fff8ef", padx=24, pady=22)
		card.pack(fill="both", expand=True)

		title = tk.Label(
			card,
			text="Stark gespielt!",
			font=("Bahnschrift", 24, "bold"),
			fg="#1f2933",
			bg="#fff8ef",
		)
		title.pack(pady=(0, 8))

		message = tk.Label(
			card,
			text=f"Du hast das Sudoku ({self._difficulty_label()}) korrekt geloest.",
			font=("Trebuchet MS", 12),
			fg="#52606d",
			bg="#fff8ef",
		)
		message.pack(pady=(0, 18))

		button_row = tk.Frame(card, bg="#fff8ef")
		button_row.pack()

		new_game_btn = tk.Button(
			button_row,
			text="Neues Spiel",
			font=("Trebuchet MS", 11, "bold"),
			fg="white",
			bg="#007f73",
			activebackground="#005a53",
			activeforeground="white",
			relief="flat",
			cursor="hand2",
			padx=16,
			pady=8,
			command=lambda: self._start_new_game_from_popup(popup),
		)
		new_game_btn.pack(side="left", padx=6)

		close_btn = tk.Button(
			button_row,
			text="Schliessen",
			font=("Trebuchet MS", 11, "bold"),
			fg="#264653",
			bg="#fde8c8",
			activebackground="#f8d9a8",
			activeforeground="#264653",
			relief="flat",
			cursor="hand2",
			padx=16,
			pady=8,
			command=popup.destroy,
		)
		close_btn.pack(side="left", padx=6)

	def _start_new_game_from_popup(self, popup):
		popup.destroy()
		self.generate_new(self.current_difficulty)


def main():
	root = tk.Tk()
	SudokuApp(root)
	root.mainloop()


if __name__ == "__main__":
	main()
